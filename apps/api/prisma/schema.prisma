generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  USER
}

enum WorkStatus {
  IN_OFFICE
  REMOTE
  VACATION
  SICK_LEAVE
  BUSINESS_TRIP
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DocumentStatus {
  DRAFT
  IN_PROGRESS
  APPROVED
  REJECTED
}

enum RouteType {
  SEQUENTIAL
  PARALLEL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model User {
  id                       String                    @id @default(cuid())
  email                    String                    @unique
  passwordHash             String
  name                     String
  personnelNumber          String?
  lastName                 String?
  firstName                String?
  middleName               String?
  birthDate                DateTime?
  hireDate                 DateTime?
  terminationDate          DateTime?
  department               String?
  unitBureau               String?
  position                 String?
  managerName              String?
  phones                   Json                      @default("[]")
  photoUrl                 String?
  workStatus               WorkStatus                @default(IN_OFFICE)
  location                 String?
  bio                      String?
  skills                   Json                      @default("[]")
  role                     UserRole                  @default(USER)
  isActive                 Boolean                   @default(true)
  isOnboarded              Boolean                   @default(false)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  newsPosts                NewsPost[]
  newsLikes                NewsLike[]
  newsComments             NewsComment[]
  createdTasks             Task[]                    @relation("TaskCreator")
  assignedTasks            Task[]                    @relation("TaskAssignee")
  createdConversations     Conversation[]            @relation("ConversationCreator")
  conversationParticipants ConversationParticipant[]
  chatMessages             ChatMessage[]
  notifications            Notification[]

  createdDocuments         Document[]          @relation("DocumentCreator")
  approvals                ApprovalRouteItem[] @relation("DocumentApprover")

  createdTickets           Ticket[]            @relation("TicketAuthor")
  assignedTickets          Ticket[]            @relation("TicketAssignee")
  ticketComments           TicketComment[]

  workShifts               WorkShift[]

  @@index([isActive, name, email])
  @@index([personnelNumber])
  @@index([isActive, lastName, firstName, middleName])
  @@index([department, unitBureau])
  @@map("users")
}

model NewsPost {
  id          String        @id @default(cuid())
  title       String
  content     String
  attachments Json          @default("[]")
  isPublished Boolean       @default(true)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  authorId    String
  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes       NewsLike[]
  comments    NewsComment[]

  @@index([isPublished, publishedAt, createdAt])
  @@index([authorId])
  @@map("news_posts")
}

model NewsLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      NewsPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
  @@map("news_likes")
}

model NewsComment {
  id        String        @id @default(cuid())
  content   String
  postId    String
  authorId  String
  parentId  String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  post      NewsPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    NewsComment?  @relation("NewsCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   NewsComment[] @relation("NewsCommentReplies")

  @@index([postId, createdAt])
  @@index([postId, parentId, createdAt])
  @@index([authorId])
  @@index([parentId])
  @@map("news_comments")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueAt       DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  creatorId   String
  assigneeId  String?
  creator     User         @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([status, dueAt])
  @@index([priority])
  @@index([creatorId])
  @@index([assigneeId])
  @@index([createdAt])
  @@index([creatorId, createdAt])
  @@index([assigneeId, createdAt])
  @@map("tasks")
}

model Conversation {
  id           String                    @id @default(cuid())
  title        String?
  isGroup      Boolean                   @default(false)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  createdById  String
  createdBy    User                      @relation("ConversationCreator", fields: [createdById], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages     ChatMessage[]

  @@index([createdById])
  @@index([updatedAt])
  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([userId, conversationId])
  @@map("conversation_participants")
}

model ChatMessage {
  id             String       @id @default(cuid())
  content        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversationId String
  authorId       String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([authorId])
  @@map("chat_messages")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  type      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model Document {
  id          String         @id @default(cuid())
  title       String
  content     String         @db.Text
  status      DocumentStatus @default(DRAFT)
  routeType   RouteType      @default(SEQUENTIAL)
  authorId    String
  author      User           @relation("DocumentCreator", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  approvalRoute ApprovalRouteItem[]

  @@index([authorId])
  @@index([status])
  @@map("documents")
}

model ApprovalRouteItem {
  id          String         @id @default(cuid())
  documentId  String
  document    Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId      String
  user        User           @relation("DocumentApprover", fields: [userId], references: [id], onDelete: Cascade)
  order       Int            @default(0)
  status      ApprovalStatus @default(PENDING)
  comment     String?        @db.Text
  decidedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([documentId])
  @@index([userId])
  @@index([status])
  @@map("approval_route_items")
}

model TicketCategory {
  id          String   @id @default(cuid())
  name        String
  description String?
  tickets     Ticket[]

  @@map("ticket_categories")
}

model Ticket {
  id          String       @id @default(cuid())
  title       String
  description String       @db.Text
  status      TicketStatus @default(OPEN)
  
  categoryId  String
  category    TicketCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  authorId    String
  author      User         @relation("TicketAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  
  assigneeId  String?
  assignee    User?        @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  comments    TicketComment[]

  @@index([authorId])
  @@index([assigneeId])
  @@index([status])
  @@index([categoryId])
  @@map("tickets")
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ticketId])
  @@index([authorId])
  @@map("ticket_comments")
}

enum WorkShiftStatus {
  ACTIVE
  CLOSED
}

model WorkShift {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  startTime  DateTime        @default(now())
  endTime    DateTime?
  durationMs Int?
  status     WorkShiftStatus @default(ACTIVE)

  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([userId])
  @@index([status])
  @@map("work_shifts")
}
